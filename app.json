{
  "expo": {
    "name": "ZuperApps Mobile Builder",
    "slug": "zuperapps_mobile_builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/zuperapps_logo.png",
    "scheme": "zuperapps_mobile_builder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karthi-vs.zuperapps-mobile-builder"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.karthi_vs.zuperapps_mobile_builder"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logos/zuperapps_logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
